/.claude/skills/submit-h1/

# Ignore all archive/ content by default — it's old experiments, hunt
# outputs, exploit artifacts (PHAR/ZIP), etc. The four `old_*` subdirs
# below stay tracked (see negative rules earlier in this file).
archive/demos_dir/
archive/docs/
archive/exploit_artifacts/
archive/hunt_results/
archive/ml_dir/
archive/powershell_scripts/
archive/redteam/
archive/stale_state/
archive/temp/
archive/tests/
archive/tests_dir/
archive/tests_root/
archive/viper_v2/
archive/*.txt
archive/requirements.txt

# Runtime locks (session state, never commit)
.claude/*.lock

# Absorbed external Agent-Skills (operator-local, generated by `viper.py skills import`)
data/imported_skills.json

# Operator-configured external MCP servers (may hold local paths/keys)
config/mcp_servers.json
