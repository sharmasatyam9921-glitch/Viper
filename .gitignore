# ── Sanitization rails (see _quarantine/ for what was moved out) ──
# Quarantine bucket — never commit anything here. Bulk-delete this dir
# when you no longer need the artifacts.
/_quarantine/

# Root-level PDFs and outputs (almost always pentest/CTF exfil)
/*.pdf
/*.docx
/attack_output.txt
/*_output.txt
/*_results.txt
/*_response.txt
/*_dump.txt
/*.eml

# Root-level CTF / scratch scripts. Real VIPER code lives in core/,
# tools/, pentest/, agents/, recon/ — root-level scripts here are
# session-specific solve scripts and shouldn't be committed.
/ctf_*.py
/hack_*.py
/pwn_*.py
/solve_*.py
/exploit_*.py
/probe_*.py
